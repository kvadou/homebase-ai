generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique @map("clerk_id")
  email     String   @unique
  firstName String?  @map("first_name")
  lastName  String?  @map("last_name")
  imageUrl  String?  @map("image_url")
  isAdmin   Boolean  @default(false) @map("is_admin")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  calendarToken String?  @unique @map("calendar_token")

  homes             HomeUser[]
  chatSessions      ChatSession[]
  notifications     Notification[]
  pushSubscriptions PushSubscription[]
  subscription      Subscription?
  realtorAccount    RealtorAccount?
  supportTickets    SupportTicket[]

  @@map("users")
}

model Home {
  id          String   @id @default(cuid())
  name        String
  address     String?
  city        String?
  state       String?
  zipCode     String?  @map("zip_code")
  country     String?  @default("US")
  homeType    String?  @map("home_type")
  yearBuilt   Int?     @map("year_built")
  squareFeet  Int?     @map("square_feet")
  photoUrl    String?  @map("photo_url")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Phase 5: Geocoding + valuation
  latitude            Float?
  longitude           Float?
  estimatedValue      Float?    @map("estimated_value")
  lastValuationDate   DateTime? @map("last_valuation_date")
  lastValuationSource String?   @map("last_valuation_source")

  users           HomeUser[]
  rooms           Room[]
  items           Item[]
  chatSessions    ChatSession[]
  serviceRequests ServiceRequest[]
  homePassport    HomePassport?
  invitations     HomeInvitation[]
  insuranceClaims InsuranceClaim[]
  events          HomeEvent[]
  issues          HomeIssue[]
  safetyInfo      SafetyInfo[]

  @@map("homes")
}

model HomeUser {
  id     String @id @default(cuid())
  userId String @map("user_id")
  homeId String @map("home_id")
  role   String @default("owner")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  home Home @relation(fields: [homeId], references: [id], onDelete: Cascade)

  @@unique([userId, homeId])
  @@map("home_users")
}

model Room {
  id          String   @id @default(cuid())
  homeId      String   @map("home_id")
  name        String
  roomType    String   @map("room_type")
  floor       Int?     @default(1)
  description String?
  photoUrl    String?  @map("photo_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Phase 5: Paint tracking
  paintBrand        String?   @map("paint_brand")
  paintColor        String?   @map("paint_color")
  paintFinish       String?   @map("paint_finish")
  paintSheen        String?   @map("paint_sheen")
  paintPurchaseDate DateTime? @map("paint_purchase_date")

  home   Home        @relation(fields: [homeId], references: [id], onDelete: Cascade)
  items  Item[]
  issues HomeIssue[]

  @@map("rooms")
}

model Item {
  id              String   @id @default(cuid())
  homeId          String   @map("home_id")
  roomId          String?  @map("room_id")
  name            String
  category        String
  brand           String?
  model           String?
  serialNumber    String?  @map("serial_number")
  modelNumber     String?  @map("model_number")
  purchaseDate    DateTime? @map("purchase_date")
  purchasePrice   Float?    @map("purchase_price")
  warrantyExpiry   DateTime? @map("warranty_expiry")
  warrantyProvider String?   @map("warranty_provider")
  warrantyType     String?   @map("warranty_type")
  warrantyNotes    String?   @map("warranty_notes")
  condition        String?   @default("good")
  description     String?
  photoUrl        String?   @map("photo_url")
  notes           String?
  smartDeviceId       String?   @map("smart_device_id")
  smartDeviceType     String?   @map("smart_device_type")
  smartDeviceMetadata Json?     @map("smart_device_metadata")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  home             Home              @relation(fields: [homeId], references: [id], onDelete: Cascade)
  room             Room?             @relation(fields: [roomId], references: [id], onDelete: SetNull)
  manuals          ItemManual[]
  documents        ItemDocument[]
  maintenanceTasks MaintenanceTask[]
  recalls          ItemRecall[]
  parts            Part[]

  @@map("items")
}

model Manual {
  id          String   @id @default(cuid())
  title       String
  brand       String?
  model       String?
  fileUrl     String?  @map("file_url")
  sourceUrl   String?  @map("source_url")
  fileType    String?  @map("file_type")
  pageCount   Int?     @map("page_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  chunks ManualChunk[]
  items  ItemManual[]

  @@map("manuals")
}

model ManualChunk {
  id        String                 @id @default(cuid())
  manualId  String                 @map("manual_id")
  content   String
  pageNumber Int?                  @map("page_number")
  chunkIndex Int                   @map("chunk_index")
  embedding  Unsupported("vector(1536)")?
  createdAt DateTime               @default(now()) @map("created_at")

  manual Manual @relation(fields: [manualId], references: [id], onDelete: Cascade)

  @@map("manual_chunks")
}

model ItemManual {
  id       String @id @default(cuid())
  itemId   String @map("item_id")
  manualId String @map("manual_id")

  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  manual Manual @relation(fields: [manualId], references: [id], onDelete: Cascade)

  @@unique([itemId, manualId])
  @@map("item_manuals")
}

model ItemDocument {
  id        String   @id @default(cuid())
  itemId    String   @map("item_id")
  name      String
  fileUrl   String   @map("file_url")
  fileType  String?  @map("file_type")
  fileSize  Int?     @map("file_size")
  createdAt DateTime @default(now()) @map("created_at")

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("item_documents")
}

model MaintenanceTask {
  id           String    @id @default(cuid())
  itemId       String    @map("item_id")
  title        String
  description  String?
  frequency    String?
  nextDueDate  DateTime? @map("next_due_date")
  priority     String?   @default("medium")
  status       String    @default("pending")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  item Item              @relation(fields: [itemId], references: [id], onDelete: Cascade)
  logs MaintenanceLog[]

  @@map("maintenance_tasks")
}

model MaintenanceLog {
  id        String   @id @default(cuid())
  taskId    String   @map("task_id")
  notes     String?
  cost      Float?
  performedAt DateTime @default(now()) @map("performed_at")
  performedBy String?  @map("performed_by")
  createdAt DateTime @default(now()) @map("created_at")

  task MaintenanceTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("maintenance_logs")
}

model ChatSession {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  homeId    String?  @map("home_id")
  title     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  home     Home?         @relation(fields: [homeId], references: [id], onDelete: SetNull)
  messages ChatMessage[]

  @@map("chat_sessions")
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String   @map("session_id")
  role      String
  content   String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

model ProviderProfile {
  id              String   @id @default(cuid())
  name            String
  company         String?
  specialty       String
  phone           String?
  email           String?
  website         String?
  address         String?
  rating          Float?   @default(0)
  reviewCount     Int      @default(0) @map("review_count")
  isVerified      Boolean  @default(false) @map("is_verified")
  stripeConnectId String?  @map("stripe_connect_id")
  isClaimable     Boolean  @default(true) @map("is_claimable")
  claimedByUserId String?  @map("claimed_by_user_id")
  commissionRate  Float?   @default(0.10) @map("commission_rate")
  featured        Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Phase 5: External API fields
  googlePlaceId  String?  @unique @map("google_place_id")
  yelpId         String?  @unique @map("yelp_id")
  source         String?  @default("manual") @map("source")
  hoursJson      Json?    @map("hours_json")
  photoUrls      Json?    @map("photo_urls")
  priceLevel     String?  @map("price_level")
  latitude       Float?
  longitude      Float?

  reviews        ProviderReview[]
  availability   ProviderAvailability[]
  serviceRequests ServiceRequest[]

  @@map("provider_profiles")
}

model ServiceRequest {
  id               String    @id @default(cuid())
  homeId           String    @map("home_id")
  providerId       String?   @map("provider_id")
  title            String
  description      String?
  status           String    @default("pending")
  priority         String?   @default("medium")
  scheduledAt      DateTime? @map("scheduled_at")
  completedAt      DateTime? @map("completed_at")
  cost             Float?
  commissionRate   Float?    @map("commission_rate")
  commissionAmount Float?    @map("commission_amount")
  paymentStatus    String?   @map("payment_status")
  stripePaymentId  String?   @map("stripe_payment_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  home     Home             @relation(fields: [homeId], references: [id], onDelete: Cascade)
  provider ProviderProfile? @relation(fields: [providerId], references: [id], onDelete: SetNull)

  @@map("service_requests")
}

model ProviderReview {
  id         String   @id @default(cuid())
  providerId String   @map("provider_id")
  userId     String?  @map("user_id")
  rating     Int
  comment    String?
  authorName String?  @map("author_name")
  isVerified Boolean  @default(false) @map("is_verified")
  createdAt  DateTime @default(now()) @map("created_at")

  provider ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("provider_reviews")
}

model ProviderAvailability {
  id         String @id @default(cuid())
  providerId String @map("provider_id")
  dayOfWeek  Int    @map("day_of_week")
  startTime  String @map("start_time")
  endTime    String @map("end_time")

  provider ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("provider_availability")
}

model ItemRecall {
  id          String   @id @default(cuid())
  itemId      String   @map("item_id")
  title       String
  description String?
  severity    String?
  recallDate  DateTime? @map("recall_date")
  sourceUrl   String?   @map("source_url")
  createdAt   DateTime  @default(now()) @map("created_at")

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("item_recalls")
}

model Part {
  id          String  @id @default(cuid())
  itemId      String  @map("item_id")
  name        String
  partNumber  String? @map("part_number")
  manufacturer String?
  price       Float?
  sourceUrl   String? @map("source_url")
  notes       String?

  // Phase 5: Filter/replacement tracking
  filterSize          String?   @map("filter_size")
  quantity            Int?
  lastReplacedDate    DateTime? @map("last_replaced_date")
  replacementInterval String?   @map("replacement_interval")

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("parts")
}

model HomePassport {
  id             String    @id @default(cuid())
  homeId         String    @unique @map("home_id")
  data           Json      @default("{}")
  generatedAt    DateTime? @map("generated_at")
  shareToken     String?   @unique @map("share_token")
  shareExpiresAt DateTime? @map("share_expires_at")
  isPublic       Boolean   @default(false) @map("is_public")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  home Home @relation(fields: [homeId], references: [id], onDelete: Cascade)

  @@map("home_passports")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String
  title     String
  body      String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

model HomeInvitation {
  id        String   @id @default(cuid())
  homeId    String   @map("home_id")
  email     String
  role      String   @default("editor")
  token     String   @unique
  status    String   @default("pending")
  invitedBy String   @map("invited_by")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  home Home @relation(fields: [homeId], references: [id], onDelete: Cascade)

  @@index([email, status])
  @@index([token])
  @@map("home_invitations")
}

model PushSubscription {
  id       String @id @default(cuid())
  userId   String @map("user_id")
  endpoint String @unique
  p256dh   String
  auth     String
  platform String? @default("web")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

model Subscription {
  id                    String    @id @default(cuid())
  userId                String    @unique @map("user_id")
  stripeCustomerId      String?   @unique @map("stripe_customer_id")
  stripeSubscriptionId  String?   @unique @map("stripe_subscription_id")
  stripePriceId         String?   @map("stripe_price_id")
  plan                  String    @default("free")
  status                String    @default("active")
  currentPeriodStart    DateTime? @map("current_period_start")
  currentPeriodEnd      DateTime? @map("current_period_end")
  cancelAtPeriodEnd     Boolean   @default(false) @map("cancel_at_period_end")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@map("subscriptions")
}

// ===== Phase 5: New Models =====

model InsuranceClaim {
  id             String   @id @default(cuid())
  homeId         String   @map("home_id")
  title          String
  incidentDate   DateTime @map("incident_date")
  incidentType   String   @map("incident_type")
  description    String?
  status         String   @default("draft")
  totalValue     Float?   @map("total_value")
  itemIds        Json?    @map("item_ids")
  aiNarrative    String?  @map("ai_narrative")
  pdfUrl         String?  @map("pdf_url")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  home Home @relation(fields: [homeId], references: [id], onDelete: Cascade)

  @@map("insurance_claims")
}

model HomeEvent {
  id          String   @id @default(cuid())
  homeId      String   @map("home_id")
  type        String   // maintenance|purchase|improvement|warranty|custom
  title       String
  description String?
  date        DateTime
  cost        Float?
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  home Home @relation(fields: [homeId], references: [id], onDelete: Cascade)

  @@map("home_events")
}

model HomeIssue {
  id             String   @id @default(cuid())
  homeId         String   @map("home_id")
  roomId         String?  @map("room_id")
  title          String
  description    String?
  severity       String   // cosmetic|moderate|urgent|critical
  aiDiagnosis    String?  @map("ai_diagnosis")
  estimatedCost  String?  @map("estimated_cost")
  photoUrl       String?  @map("photo_url")
  status         String   @default("identified")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  home Home  @relation(fields: [homeId], references: [id], onDelete: Cascade)
  room Room? @relation(fields: [roomId], references: [id])

  @@map("home_issues")
}

model SafetyInfo {
  id          String   @id @default(cuid())
  homeId      String   @map("home_id")
  type        String   // shutoff_water|shutoff_gas|shutoff_electrical|emergency_contact|evacuation_note|go_bag_item
  title       String
  description String?
  location    String?
  photoUrl    String?  @map("photo_url")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  home Home @relation(fields: [homeId], references: [id], onDelete: Cascade)

  @@map("safety_info")
}

model RealtorAccount {
  id            String   @id @default(cuid())
  userId        String   @unique @map("user_id")
  company       String?
  licenseNumber String?  @map("license_number")
  territory     String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("realtor_accounts")
}

// ===== Phase 6: Admin Portal Models =====

model SupportTicket {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  homeId      String?   @map("home_id")
  subject     String
  description String
  status      String    @default("open") // open|in_progress|resolved|closed
  priority    String    @default("medium") // low|medium|high|urgent
  category    String?
  assignedTo  String?   @map("assigned_to")
  resolvedAt  DateTime? @map("resolved_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages SupportMessage[]

  @@index([userId])
  @@index([status])
  @@map("support_tickets")
}

model SupportMessage {
  id         String   @id @default(cuid())
  ticketId   String   @map("ticket_id")
  senderType String   @map("sender_type") // customer|admin
  senderName String   @map("sender_name")
  content    String
  createdAt  DateTime @default(now()) @map("created_at")

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("support_messages")
}

model MarketingCampaign {
  id          String    @id @default(cuid())
  name        String
  channel     String    // email|social|search|content
  status      String    @default("draft") // draft|active|paused|completed
  description String?
  budget      Float?
  spent       Float?
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  metrics     Json?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  content MarketingContent[]

  @@map("marketing_campaigns")
}

model MarketingContent {
  id          String    @id @default(cuid())
  campaignId  String?   @map("campaign_id")
  type        String    // blog|social|email|ad_copy
  title       String
  content     String
  platform    String?
  status      String    @default("draft") // draft|published|scheduled
  aiGenerated Boolean   @default(false) @map("ai_generated")
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  campaign MarketingCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@map("marketing_content")
}
