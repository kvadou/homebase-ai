generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique @map("clerk_id")
  email     String   @unique
  firstName String?  @map("first_name")
  lastName  String?  @map("last_name")
  imageUrl  String?  @map("image_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  homes        HomeUser[]
  chatSessions ChatSession[]

  @@map("users")
}

model Home {
  id          String   @id @default(cuid())
  name        String
  address     String?
  city        String?
  state       String?
  zipCode     String?  @map("zip_code")
  country     String?  @default("US")
  homeType    String?  @map("home_type")
  yearBuilt   Int?     @map("year_built")
  squareFeet  Int?     @map("square_feet")
  photoUrl    String?  @map("photo_url")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users           HomeUser[]
  rooms           Room[]
  items           Item[]
  chatSessions    ChatSession[]
  serviceRequests ServiceRequest[]
  homePassport    HomePassport?

  @@map("homes")
}

model HomeUser {
  id     String @id @default(cuid())
  userId String @map("user_id")
  homeId String @map("home_id")
  role   String @default("owner")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  home Home @relation(fields: [homeId], references: [id], onDelete: Cascade)

  @@unique([userId, homeId])
  @@map("home_users")
}

model Room {
  id          String   @id @default(cuid())
  homeId      String   @map("home_id")
  name        String
  roomType    String   @map("room_type")
  floor       Int?     @default(1)
  description String?
  photoUrl    String?  @map("photo_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  home  Home   @relation(fields: [homeId], references: [id], onDelete: Cascade)
  items Item[]

  @@map("rooms")
}

model Item {
  id              String   @id @default(cuid())
  homeId          String   @map("home_id")
  roomId          String?  @map("room_id")
  name            String
  category        String
  brand           String?
  model           String?
  serialNumber    String?  @map("serial_number")
  modelNumber     String?  @map("model_number")
  purchaseDate    DateTime? @map("purchase_date")
  purchasePrice   Float?    @map("purchase_price")
  warrantyExpiry  DateTime? @map("warranty_expiry")
  condition       String?   @default("good")
  description     String?
  photoUrl        String?   @map("photo_url")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  home             Home              @relation(fields: [homeId], references: [id], onDelete: Cascade)
  room             Room?             @relation(fields: [roomId], references: [id], onDelete: SetNull)
  manuals          ItemManual[]
  documents        ItemDocument[]
  maintenanceTasks MaintenanceTask[]
  recalls          ItemRecall[]
  parts            Part[]

  @@map("items")
}

model Manual {
  id          String   @id @default(cuid())
  title       String
  brand       String?
  model       String?
  fileUrl     String?  @map("file_url")
  sourceUrl   String?  @map("source_url")
  fileType    String?  @map("file_type")
  pageCount   Int?     @map("page_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  chunks ManualChunk[]
  items  ItemManual[]

  @@map("manuals")
}

model ManualChunk {
  id        String                 @id @default(cuid())
  manualId  String                 @map("manual_id")
  content   String
  pageNumber Int?                  @map("page_number")
  chunkIndex Int                   @map("chunk_index")
  embedding  Unsupported("vector(1536)")?
  createdAt DateTime               @default(now()) @map("created_at")

  manual Manual @relation(fields: [manualId], references: [id], onDelete: Cascade)

  @@map("manual_chunks")
}

model ItemManual {
  id       String @id @default(cuid())
  itemId   String @map("item_id")
  manualId String @map("manual_id")

  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  manual Manual @relation(fields: [manualId], references: [id], onDelete: Cascade)

  @@unique([itemId, manualId])
  @@map("item_manuals")
}

model ItemDocument {
  id        String   @id @default(cuid())
  itemId    String   @map("item_id")
  name      String
  fileUrl   String   @map("file_url")
  fileType  String?  @map("file_type")
  fileSize  Int?     @map("file_size")
  createdAt DateTime @default(now()) @map("created_at")

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("item_documents")
}

model MaintenanceTask {
  id           String    @id @default(cuid())
  itemId       String    @map("item_id")
  title        String
  description  String?
  frequency    String?
  nextDueDate  DateTime? @map("next_due_date")
  priority     String?   @default("medium")
  status       String    @default("pending")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  item Item              @relation(fields: [itemId], references: [id], onDelete: Cascade)
  logs MaintenanceLog[]

  @@map("maintenance_tasks")
}

model MaintenanceLog {
  id        String   @id @default(cuid())
  taskId    String   @map("task_id")
  notes     String?
  cost      Float?
  performedAt DateTime @default(now()) @map("performed_at")
  performedBy String?  @map("performed_by")
  createdAt DateTime @default(now()) @map("created_at")

  task MaintenanceTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("maintenance_logs")
}

model ChatSession {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  homeId    String?  @map("home_id")
  title     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  home     Home?         @relation(fields: [homeId], references: [id], onDelete: SetNull)
  messages ChatMessage[]

  @@map("chat_sessions")
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String   @map("session_id")
  role      String
  content   String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

model ProviderProfile {
  id           String   @id @default(cuid())
  name         String
  company      String?
  specialty    String
  phone        String?
  email        String?
  website      String?
  address      String?
  rating       Float?   @default(0)
  reviewCount  Int      @default(0) @map("review_count")
  isVerified   Boolean  @default(false) @map("is_verified")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  reviews        ProviderReview[]
  availability   ProviderAvailability[]
  serviceRequests ServiceRequest[]

  @@map("provider_profiles")
}

model ServiceRequest {
  id          String   @id @default(cuid())
  homeId      String   @map("home_id")
  providerId  String?  @map("provider_id")
  title       String
  description String?
  status      String   @default("pending")
  priority    String?  @default("medium")
  scheduledAt DateTime? @map("scheduled_at")
  completedAt DateTime? @map("completed_at")
  cost        Float?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  home     Home             @relation(fields: [homeId], references: [id], onDelete: Cascade)
  provider ProviderProfile? @relation(fields: [providerId], references: [id], onDelete: SetNull)

  @@map("service_requests")
}

model ProviderReview {
  id         String   @id @default(cuid())
  providerId String   @map("provider_id")
  rating     Int
  comment    String?
  authorName String?  @map("author_name")
  createdAt  DateTime @default(now()) @map("created_at")

  provider ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("provider_reviews")
}

model ProviderAvailability {
  id         String @id @default(cuid())
  providerId String @map("provider_id")
  dayOfWeek  Int    @map("day_of_week")
  startTime  String @map("start_time")
  endTime    String @map("end_time")

  provider ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("provider_availability")
}

model ItemRecall {
  id          String   @id @default(cuid())
  itemId      String   @map("item_id")
  title       String
  description String?
  severity    String?
  recallDate  DateTime? @map("recall_date")
  sourceUrl   String?   @map("source_url")
  createdAt   DateTime  @default(now()) @map("created_at")

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("item_recalls")
}

model Part {
  id          String  @id @default(cuid())
  itemId      String  @map("item_id")
  name        String
  partNumber  String? @map("part_number")
  manufacturer String?
  price       Float?
  sourceUrl   String? @map("source_url")
  notes       String?

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("parts")
}

model HomePassport {
  id        String   @id @default(cuid())
  homeId    String   @unique @map("home_id")
  data      Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  home Home @relation(fields: [homeId], references: [id], onDelete: Cascade)

  @@map("home_passports")
}
